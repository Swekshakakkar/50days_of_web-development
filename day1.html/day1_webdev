<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Foodies_fav</title>
    <link rel="stylesheet" href="base.css">
</head>
 <style>
   
  * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  /* Dark Red Navbar */
  .navbar {
      background-color: #c42d2d; /* Dark Red color */
      padding: 15px 30px;
      display: flex;
      gap: 30px; /* Words ke beech ka gap */
  }

  .navbar span {
      color: white;
      font-size: 18px;
      cursor: pointer;
  }

  /* Orange/Peach Hero Section */
  .hero-section {
      background-color: #e67359; /* Peach/Orange shade */
      height: 350px;
      color: white;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
  }

  .hero-section h1 {
      font-size: 40px;
      margin-bottom: 10px;
  }

  .hero-section p {
      font-size: 20px;
  }

  /* Bottom Content Area */
  .content {
      padding: 40px;
      background-color: #fff9f5; /* Light cream background */
  }

  .content h2 {
      color: #c42d2d;
      font-size: 32px;
      margin-bottom: 15px;
      margin-top: 20px;
  }

  .content p {
      font-size: 18px;
      color: #333;
  }

    
 </style>
<body>
    
    <nav class="navbar">
    <span>Home</span>
    <span>Menu</span>
    <span>Offers</span>
    <span>Contact</span>
</nav>

<div class="hero-section">
    <h1>Welcome to TasteHub</h1>
    <p>Order delicious food near you</p>
</div>
   
   
   
     
</body>
</html>
